PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shoolapp
# Railway : copier MYSQLPORT (ex. 12345) — obligatoire si le port n’est pas 3306
# DB_PORT=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# SKIP_DB_MIGRATION=1   # (prod MySQL) désactive les migrations auto au démarrage — la connexion MySQL est quand même attendue
# Rendu / MySQL distant : tentatives avant échec du démarrage (défaut 30 × 2s)
# DB_STARTUP_MAX_ATTEMPTS=30
# DB_STARTUP_DELAY_MS=2000
# DB_CONNECT_TIMEOUT_MS=20000
# DB_POOL_LIMIT=10

# Production : minimum 32 caractères (le serveur refuse au démarrage sinon).
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_minimum_32_caracteres
JWT_EXPIRES_IN=12h
ADMIN_COOKIE_NAME=sa_admin
# Production : uniquement https://… (séparateur virgule si plusieurs origines). Pas de wildcard.
CORS_ORIGIN=http://localhost:3001
# Production cross-origin (Vercel + API Render) : laisser none (défaut) ou mettre lax si front et API même site.
# ADMIN_COOKIE_SAMESITE=none
JSON_BODY_LIMIT=200kb
UPLOAD_PATH=./uploads

# Notifications email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_FROM=
# Ancienne variable (une ou plusieurs adresses). Utilisée si NOTIFY_TEAM_EMAILS absent.
NOTIFY_EMAIL_TO=

# Inscriptions + orientation : boîtes **équipe** qui **reçoivent** les alertes (défaut : admissions + info Abidjan).
NOTIFY_TEAM_EMAILS=admissions.abidjan@figs-education.com,info.abidjan@figs-education.com

# Rendez-vous uniquement : si défini, remplace NOTIFY_TEAM_EMAILS pour les mails RDV.
# NOTIFY_EMAIL_RDV=admissions.abidjan@figs-education.com,info.abidjan@figs-education.com

# Notifications WhatsApp (Meta Cloud API — messages vers les numéros **équipe**, pas les candidats)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=

# Inscriptions + orientation : numéros E.164 sans + (défaut : deux lignes conseillers Abidjan).
WHATSAPP_TEAM_TO=2250757688519,2250777552815

# Rendez-vous uniquement : si défini, remplace WHATSAPP_TEAM_TO pour les alertes RDV.
# WHATSAPP_RDV_TO=2250757688519,2250777552815
